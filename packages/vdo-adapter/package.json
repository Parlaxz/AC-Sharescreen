{
  "name": "@screenlink/vdo-adapter",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "if exist dist rmdir /s /q dist & if exist .tsbuildinfo rmdir /s /q .tsbuildinfo"
  },
  "dependencies": {
    "@screenlink/shared": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
