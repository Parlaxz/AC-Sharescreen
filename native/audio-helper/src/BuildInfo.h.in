#ifndef SCREENLINK_BUILD_INFO_H
#define SCREENLINK_BUILD_INFO_H

#include <string_view>

namespace screenlink::audio::build {

/// Git commit SHA (short form) at build time.
inline constexpr std::string_view kGitCommit = "@GIT_COMMIT@";

/// True if the working tree had uncommitted changes at build time.
inline constexpr std::string_view kGitDirty = "@GIT_DIRTY@";

/// Git branch at build time.
inline constexpr std::string_view kGitBranch = "@GIT_BRANCH@";

/// UTC build timestamp.
inline constexpr std::string_view kBuildTimestamp = "@BUILD_TIMESTAMP@";

/// Target architecture.
inline constexpr std::string_view kArchitecture = "x64";

/// Build configuration (Debug or Release).
inline constexpr std::string_view kBuildConfig = "@BUILD_CONFIG@";

/// Compiler identity.
inline constexpr std::string_view kCompilerId = "@COMPILER_ID@";

/// Protocol version (from Protocol.h, referenced at build time).
/// Included here so diagnostics consumers can read it alongside provenance.
inline constexpr std::string_view kProtocolVersion = "0.2.0";

/// Service protocol version.
inline constexpr std::string_view kServiceProtocolVersion = "0.3.0";

} // namespace screenlink::audio::build

#endif // SCREENLINK_BUILD_INFO_H
