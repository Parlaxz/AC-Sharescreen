{
  "name": "@screenlink/desktop",
  "version": "0.6.2",
  "private": true,
  "type": "module",
  "main": "./dist/main/main.js",
  "scripts": {
    "dev:renderer": "vite",
    "dev:electron": "node scripts/dev-electron.mjs",
    "dev": "node scripts/dev-electron.mjs",
    "build": "vite build && tsc -p tsconfig.main.json --outDir dist/main && tsc -p tsconfig.preload.json --outDir dist/preload",
    "build:electron": "electron-builder",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.preload.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "test": "vitest run",
    "clean": "if exist dist rmdir /s /q dist & if exist out rmdir /s /q out & if exist .vite rmdir /s /q .vite"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.2.0",
    "@radix-ui/react-checkbox": "^1.3.5",
    "@radix-ui/react-context-menu": "^2.3.1",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-navigation-menu": "^1.2.16",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-progress": "^1.1.10",
    "@radix-ui/react-radio-group": "^1.4.1",
    "@radix-ui/react-scroll-area": "^1.2.12",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slider": "^1.4.1",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.1",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@screenlink/shared": "workspace:*",
    "@screenlink/vdo-adapter": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "electron-updater": "^6.3.0",
    "lucide-react": "^0.468.0",
    "motion": "^11.15.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.0",
    "semver": "^7.6.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.0",
    "zustand": "^5.0.0"
  },
  "pnpm": {
    "overrides": {
      "react-is": "^19.0.0"
    }
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^26.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/semver": "^7.5.8",
    "@vitejs/plugin-react": "^4.3.0",
    "cmake-js": "^8.0.0",
    "electron": "42.4.1",
    "electron-builder": "^25.0.0",
    "happy-dom": "^15.0.0",
    "node-addon-api": "^8.9.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.1.2",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "build": {
    "appId": "app.screenlink.desktop",
    "productName": "ScreenLink",
    "directories": {
      "output": "out"
    },
    "files": [
      "dist/**/*",
      "public/**/*"
    ],
    "afterPack": "../../scripts/after-pack.cjs",
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "extraResources": [
      {
        "from": "public/vendor",
        "to": "vendor"
      },
      {
        "from": "assets/tray-icon.png",
        "to": "tray-icon.png"
      }
    ]
  }
}
