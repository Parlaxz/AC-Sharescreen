{
  "name": "@screenlink/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/main/main.js",
  "scripts": {
    "dev:renderer": "vite",
    "dev:electron": "node scripts/dev-electron.mjs",
    "dev": "node scripts/dev-electron.mjs",
    "build": "vite build && tsc -p tsconfig.main.json --outDir dist/main && tsc -p tsconfig.preload.json --outDir dist/preload",
    "build:electron": "electron-builder",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.preload.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "test": "vitest run",
    "clean": "if exist dist rmdir /s /q dist & if exist out rmdir /s /q out & if exist .vite rmdir /s /q .vite"
  },
  "dependencies": {
    "@screenlink/shared": "workspace:*",
    "@screenlink/vdo-adapter": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "42.4.1",
    "electron-builder": "^25.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "build": {
    "appId": "app.screenlink.desktop",
    "productName": "ScreenLink",
    "directories": {
      "output": "out"
    },
    "files": [
      "dist/**/*",
      "public/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "extraResources": [
      {
        "from": "public/vendor",
        "to": "vendor"
      }
    ]
  }
}
